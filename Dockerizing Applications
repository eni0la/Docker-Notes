#SPRING BOOT APP (JAVA)
#specify packaging type as jar
#create files including Dockerfile

DOCKERFILE
#declare baseimage
FROM openjdk:21

#create /app inside container
WORKDIR /app

#copy dependencies
COPY target/app.jar app.jar

#app listen on port
EXPOSE 5000

#command that starts app.js when container runs
CMD ["java", "-jar", "student-app.jar"] 

For production, use
ENTRYPOINT ["java", "-jar", "app.jar"] because every app should start same way, CMD can easily be replaced

FROM       = which Java environment?
WORKDIR    = where should I work?
COPY       = bring application files in
LABEL      = image information
EXPOSE     = application port
CMD        = default start command
ENTRYPOINT = fixed start command
