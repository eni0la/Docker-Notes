#Python App
#create main.py and Dockerfile
#import python packages - requirements.text

DOCKERFILE
#declare baseimage
FROM python:3.12

#create /app inside container
WORKDIR /app

#copy dependencies
COPY requirements.txt .

#copy everything inside container
COPY . .

#install packages
RUN pip install -r requirements.txt

#app listen on port
EXPOSE 5000

#command that starts app.js when container runs
CMD ["python", "app.py"]

#run python . in terminal to start app

