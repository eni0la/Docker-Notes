#Static Website
DOCKERFILE

#declare baseimage
FROM nginx:alpine

#set a work directory path\
WORKDIR use/share/nginx/html

#copy files source:destination(current:working directory)
COPY . .

#expose nginx port
EXPOSE 8080

#command that starts app when container runs
CMD ["nginx", "-g", "daemon off;"]

